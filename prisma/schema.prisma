// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  owner
  editor
  viewer
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  name         String
  documents    Document[]
  memberships  Membership[]
  updates     DocUpdate[]
  versions     Version[]
  presences    Presence[]
  createdAt DateTime @default(now())
}

model Document {
  id          String       @id @default(cuid())
  title       String
  state       Bytes
  stateVector Bytes
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  ownerId     String
  owner       User         @relation(fields: [ownerId], references: [id])
  memberships Membership[]
  updates     DocUpdate[]
  versions    Version[]
  presences   Presence[]
}

model Version {
  id         String   @id @default(cuid())
  documentId String
  label      String
  state      Bytes
  authorId   String
  createdAt  DateTime @default(now())
  document   Document @relation(fields: [documentId], references: [id])
  author     User     @relation(fields: [authorId], references: [id])

  @@index([documentId, createdAt])
}

model DocUpdate {
  id         BigInt   @id @default(autoincrement())
  documentId String
  update     Bytes
  authorId   String
  createdAt  DateTime @default(now())
  document   Document @relation(fields: [documentId], references: [id])
  author     User     @relation(fields: [authorId], references: [id])

  @@index([documentId, id])
}

model Membership {
  userId     String
  documentId String
  role       Role
  user       User     @relation(fields: [userId], references: [id])
  document   Document @relation(fields: [documentId], references: [id])

  @@id([documentId, userId])
}

// Ephemeral "who's currently here" — overwritten on every heartbeat, never
// appended to. Deliberately not the same kind of data as DocUpdate/Version,
// which are permanent history; this is just a liveness marker.
model Presence {
  userId     String
  documentId String
  lastSeenAt DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])
  document   Document @relation(fields: [documentId], references: [id])

  @@id([documentId, userId])
}
